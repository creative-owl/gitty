{
  "name": "@c8o/gitty",
  "version": "0.1.0",
  "description": "A Bun + OpenTUI terminal diff viewer for repositories and pull requests.",
  "type": "module",
  "module": "src/index.tsx",
  "bin": {
    "gitty": "./src/index.tsx"
  },
  "files": [
    "src",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/creative-owl/gitty.git"
  },
  "homepage": "https://github.com/creative-owl/gitty#readme",
  "bugs": {
    "url": "https://github.com/creative-owl/gitty/issues"
  },
  "keywords": [
    "bun",
    "diff",
    "git",
    "github",
    "pull-request",
    "terminal",
    "tui"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.14",
  "scripts": {
    "start": "bun run src/index.tsx",
    "dev": "bun --watch src/index.tsx",
    "diff": "bun run src/index.tsx",
    "diff:staged": "bun run src/index.tsx --staged",
    "test": "bun test",
    "check": "bun run typecheck && bun test",
    "typecheck": "bunx tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/jsdom": "^28.0.3",
    "@types/react": "^19.2.17",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@opentui/core": "^0.1.89",
    "@opentui/react": "^0.1.89",
    "@pierre/diffs": "1.2.2",
    "hunkdiff": "^0.15.3",
    "jsdom": "^29.1.1",
    "marked": "17.0.1",
    "mermaid": "^11.15.0",
    "react": "^19.2.4",
    "sharp": "^0.35.1"
  }
}
