    "@pierre/diffs": "1.2.2",
    "hunkdiff": "^0.15.3",
    "jsdom": "^29.1.1",
    "marked": "17.0.1",
    "mermaid": "^11.15.0",
    "react": "^19.2.4",
    "sharp": "^0.35.1"
  }
